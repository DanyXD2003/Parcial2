@page
@model Parcial2.Pages.IndexModel
@{
    ViewData["Title"]      = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">Dashboard</h4>
        <small class="text-muted">@DateTime.UtcNow.ToString("dddd, dd MMMM yyyy")</small>
    </div>
</div>

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">Ventas hoy</div>
                <div class="fs-3 fw-bold text-primary">@Model.TodaySalesCount</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">Ingresos hoy</div>
                <div class="fs-3 fw-bold text-success">Q @Model.TodayRevenue.ToString("N2")</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">Productos activos</div>
                <div class="fs-3 fw-bold text-info">@Model.TotalActiveProducts</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">Stock bajo</div>
                <div class="fs-3 fw-bold @(Model.LowStockCount > 0 ? "text-warning" : "")">@Model.LowStockCount</div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Sales + Quick Access -->
<div class="row g-3">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header bg-white fw-semibold py-3">Ultimas ventas</div>
            <div class="card-body p-0">
                @if (!Model.RecentSales.Any())
                {
                    <div class="text-center text-muted py-4">
                        <p class="mb-0">No hay ventas registradas aun</p>
                    </div>
                }
                else
                {
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Fecha</th>
                                <th>Cajero</th>
                                <th>Items</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sale in Model.RecentSales)
                            {
                                <tr>
                                    <td class="text-muted">@sale.Id</td>
                                    <td>@sale.SaleDate.ToString("dd/MM HH:mm")</td>
                                    <td>@sale.User.Username</td>
                                    <td>@sale.SaleItems.Sum(si => si.Quantity)</td>
                                    <td class="fw-semibold text-success">Q @sale.TotalAmount.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header bg-white fw-semibold py-3">Acceso rapido</div>
            <div class="card-body d-grid gap-2">
                <a asp-page="/Products/Index" class="btn btn-outline-primary">Ver Productos</a>
                <a asp-page="/Cart/Index" class="btn btn-outline-success">Carrito</a>
                <a asp-page="/Sales/Index" class="btn btn-outline-secondary">Historial de Ventas</a>
                <a asp-page="/Products/Create" class="btn btn-outline-info">Nuevo Producto</a>
                <a asp-page="/Reports/Index" class="btn btn-outline-warning">Ver Reportes</a>
            </div>
        </div>
    </div>
</div>
