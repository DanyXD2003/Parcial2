@page
@model Parcial2.Pages.Products.CreateModel
@{
    ViewData["Title"]      = "Nuevo Producto";
    ViewData["ActivePage"] = "Products";
}

<div class="mb-4">
    <a asp-page="Index" class="text-muted text-decoration-none small">Volver a Productos</a>
    <h4 class="fw-bold mt-2 mb-0">Nuevo Producto</h4>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-body">
                <form method="post">
                    <div class="mb-3">
                        <label asp-for="Input.Name" class="form-label fw-semibold">Nombre *</label>
                        <input asp-for="Input.Name" class="form-control" placeholder="Ej: Leche Entera 1L" />
                        <span asp-validation-for="Input.Name" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.Description" class="form-label fw-semibold">Descripcion</label>
                        <input asp-for="Input.Description" class="form-control" placeholder="Descripcion breve del producto" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.Category" class="form-label fw-semibold">Categoria *</label>
                        <input asp-for="Input.Category" class="form-control" placeholder="Ej: Lacteos, Bebidas, Limpieza" />
                        <span asp-validation-for="Input.Category" class="text-danger small"></span>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-sm-6">
                            <label asp-for="Input.Price" class="form-label fw-semibold">Precio *</label>
                            <div class="input-group">
                                <span class="input-group-text">Q</span>
                                <input asp-for="Input.Price" class="form-control" type="number" step="0.01" min="0.01" />
                            </div>
                            <span asp-validation-for="Input.Price" class="text-danger small"></span>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="Input.Stock" class="form-label fw-semibold">Stock inicial *</label>
                            <input asp-for="Input.Stock" class="form-control" type="number" min="0" />
                            <span asp-validation-for="Input.Stock" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Input.LowStockThreshold" class="form-label fw-semibold">Alerta stock bajo</label>
                        <input asp-for="Input.LowStockThreshold" class="form-control" type="number" min="1" />
                        <div class="form-text">Alerta cuando el stock sea menor o igual a este valor.</div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">Crear Producto</button>
                        <a asp-page="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
