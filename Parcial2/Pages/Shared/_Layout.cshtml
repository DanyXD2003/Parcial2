<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — DataMarket SA</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background-color: #f5f6fa; }
        .sidebar {
            min-height: calc(100vh - 56px);
            background: linear-gradient(180deg, #1a2535 0%, #2c3e50 100%);
            box-shadow: 2px 0 6px rgba(0,0,0,.15);
            padding-top: .75rem;
        }
        .sidebar .nav-link {
            color: #a0aab4;
            padding: .55rem 1.25rem;
            border-radius: .375rem;
            margin: .1rem .6rem;
            font-size: .875rem;
            transition: background .15s, color .15s;
        }
        .sidebar .nav-link:hover  { color: #fff; background: rgba(255,255,255,.1); }
        .sidebar .nav-link.active { color: #fff; background: rgba(52,152,219,.35); }
        .sidebar .section-label   { color: #5d6d7e; font-size: .68rem; text-transform: uppercase; padding: .75rem 1.5rem .2rem; letter-spacing: .08rem; }
        .card     { border: none; box-shadow: 0 1px 6px rgba(0,0,0,.08); }
        .table th { font-size: .78rem; color: #6c757d; font-weight: 600; text-transform: uppercase; letter-spacing: .04rem; border-top: none; }
    </style>
</head>
<body>

<nav class="navbar navbar-dark bg-dark navbar-expand fixed-top shadow-sm" style="height:56px">
    <div class="container-fluid px-3">
        <a class="navbar-brand fw-bold me-4" asp-page="/Index">DataMarket SA</a>
        <span class="text-secondary small ms-auto">Sistema de Gestion de Inventario</span>
    </div>
</nav>

<div style="margin-top:56px">
    <div class="container-fluid p-0">
        <div class="row g-0">
            <nav class="col-md-2 sidebar d-none d-md-flex flex-column">
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "active" : "")" asp-page="/Index">
                            Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Products" ? "active" : "")" asp-page="/Products/Index">
                            Productos
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Cart" ? "active" : "")" asp-page="/Cart/Index">
                            Carrito
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Sales" ? "active" : "")" asp-page="/Sales/Index">
                            Ventas
                        </a>
                    </li>
                    <li class="nav-item mt-2">
                        <span class="section-label">Administracion</span>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Reports" ? "active" : "")" asp-page="/Reports/Index">
                            Reportes
                        </a>
                    </li>
                </ul>
            </nav>
            <main class="col-md-10 p-4">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                        @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                        @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </main>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
